# Generated by setup.sh into scratch/cronjob.yaml. After generation, edit the
# --repo / --branch / --dest args below before applying to the orchestration
# cluster.

apiVersion: v1
kind: Namespace
metadata:
  name: substrate-benchmark
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: substrate-benchmark-orchestrator
  namespace: substrate-benchmark
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: substrate-benchmark
  namespace: substrate-benchmark
spec:
  schedule: "0 3 * * *"
  concurrencyPolicy: Forbid
  successfulJobsHistoryLimit: 5
  failedJobsHistoryLimit: 5
  jobTemplate:
    spec:
      backoffLimit: 0
      template:
        spec:
          restartPolicy: Never
          serviceAccountName: substrate-benchmark-orchestrator
          initContainers:
          - name: dind
            image: docker:dind
            restartPolicy: Always
            securityContext:
              privileged: true
            args:
            - --registry-mirror=https://mirror.gcr.io
            env:
            - name: DOCKER_TLS_CERTDIR
              value: ""
            volumeMounts:
            - name: docker-storage
              mountPath: /var/lib/docker
          containers:
          - name: orchestrator
            image: ${ORCHESTRATOR_IMAGE}
            imagePullPolicy: IfNotPresent
            args:
            - "--repo"
            - "<FILL IN: https://github.com/your-org/substrate.git>"
            - "--branch"
            - "<FILL IN: main>"
            - "--dest"
            - "<FILL IN: gs://your-bucket/benchmark-results>"
            env:
            - name: DOCKER_HOST
              value: tcp://localhost:2375
            volumeMounts:
            # tests.yaml is mounted via subPath so the target-clusters
            # ConfigMap can own the /etc/orchestrator/target-clusters
            # directory next to it.
            - name: tests-config
              mountPath: /etc/orchestrator/tests.yaml
              subPath: tests.yaml
              readOnly: true
            - name: target-clusters
              mountPath: /etc/orchestrator/target-clusters
              readOnly: true
            resources:
              requests:
                cpu: "1"
                memory: "2Gi"
          volumes:
          - name: docker-storage
            emptyDir: {}
          - name: tests-config
            configMap:
              name: substrate-benchmark-tests
          - name: target-clusters
            configMap:
              name: substrate-benchmark-target-clusters
